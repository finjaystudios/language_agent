APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM runtime settings.
LLM_BACKEND=llama_server
LLAMA_SERVER_URL=http://localhost:8080
LLAMA_SERVER_API_KEY=
LLAMA_SERVER_TIMEOUT_SECONDS=180
LLAMA_SERVER_STREAM_TIMEOUT_SECONDS=180
LLAMA_SERVER_MODEL_NAME=
LLAMA_SERVER_HEALTH_PATH=/health
MODEL_PROFILES_PATH=config/model_profiles.yml
REDIS_URL=redis://127.0.0.1:6379/0
LLM_QUEUE_NAME=llm
LLM_QUEUE_TIMEOUT_SECONDS=180
LLM_QUEUE_WAIT_TIMEOUT_SECONDS=300
LLM_GENERATION_TIMEOUT_SECONDS=180
LLM_RESULT_TTL_SECONDS=300
LLM_MAX_QUEUE_SIZE=100
LLM_WORKER_CONCURRENCY=1
LLM_JOB_MAX_RETRIES=2
LLM_STREAM_CHANNEL_PREFIX=llm-stream
LLM_STATUS_POLL_INTERVAL_SECONDS=0.05
LLM_STREAM_TIMEOUT_SECONDS=180

# Chainlit Web UI configuration.
FASTAPI_BASE_URL=http://localhost:8000
# Chainlit chat history uses DATABASE_URL. WEBUI_DATABASE_URL remains as an
# explicit override for Web UI auth/history when needed.
WEBUI_DATABASE_URL=postgresql+asyncpg://language_agent:change-me@127.0.0.1:5432/language_agent
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8001
WEBUI_REQUEST_TIMEOUT_SECONDS=120
WEBUI_STREAMING_ENABLED=true
CHAINLIT_COOKIE_SAMESITE=lax

# Service-to-service auth between Chainlit and FastAPI.
# Replace this placeholder in local .env or deployment secrets.
AUTH_ENABLED=true
FASTAPI_API_KEY=local-dev-change-me
CHAINLIT_AUTH_SECRET=replace-with-random-secret-when-login-is-enabled
PASSWORD_HASH_SCHEME=argon2id

# Persistent user/profile database.
POSTGRES_DB=language_agent
POSTGRES_USER=language_agent
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://language_agent:change-me@127.0.0.1:5432/language_agent
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false

# Optional browser-origin access to FastAPI.
# Chainlit calls FastAPI from server-side Python, so CORS is not required for
# the normal Web UI chat flow. Keep explicit origins only if browser access is added.
CORS_ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
