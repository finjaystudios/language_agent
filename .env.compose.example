# Copy to .env for `docker compose ...`, or pass with:
# docker compose --env-file .env.compose.example up --build

LOG_LEVEL=INFO

# Shared service-to-service API key used by both containers.
# Replace this placeholder in your local .env; do not commit real secrets.
AUTH_ENABLED=true
FASTAPI_API_KEY=local-dev-change-me
CHAINLIT_AUTH_SECRET=replace-with-random-secret-when-login-is-enabled
CHAINLIT_COOKIE_SAMESITE=lax
PASSWORD_HASH_SCHEME=argon2id
DATABASE_URL=postgresql+psycopg://language_agent:change-me@postgres:5432/language_agent
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false
POSTGRES_DB=language_agent
POSTGRES_USER=language_agent
POSTGRES_PASSWORD=change-me

# FastAPI container runtime.
APP_HOST=0.0.0.0
APP_PORT=8000
REDIS_URL=redis://redis:6379/0
LLM_BACKEND=llama_server
LLAMA_SERVER_URL=http://llama-server:8080
LLAMA_SERVER_API_KEY=
LLAMA_SERVER_TIMEOUT_SECONDS=180
LLAMA_SERVER_STREAM_TIMEOUT_SECONDS=180
LLAMA_SERVER_MODEL_NAME=
LLAMA_SERVER_HEALTH_PATH=/health
MODEL_PROFILES_PATH=config/model_profiles.yml
LLM_QUEUE_NAME=llm
LLM_QUEUE_TIMEOUT_SECONDS=180
LLM_QUEUE_WAIT_TIMEOUT_SECONDS=300
LLM_GENERATION_TIMEOUT_SECONDS=180
LLM_RESULT_TTL_SECONDS=300
LLM_MAX_QUEUE_SIZE=100
LLM_WORKER_CONCURRENCY=1
LLM_JOB_MAX_RETRIES=2
LLM_STREAM_CHANNEL_PREFIX=llm-stream
LLM_STATUS_POLL_INTERVAL_SECONDS=0.05
LLM_STREAM_TIMEOUT_SECONDS=180

# Llama-server container runtime.
LLAMA_SERVER_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_SERVER_PORT=8080
LLAMA_SERVER_HOST_PORT=8080
LLAMA_SERVER_MODEL_PATH=/models/Qwen2.5-7B-Q4_K_M.gguf
LLAMA_SERVER_CONTEXT_SIZE=2048
LLAMA_SERVER_N_GPU_LAYERS=20
LLAMA_SERVER_BATCH_SIZE=256
LLAMA_SERVER_UBATCH_SIZE=128
LLAMA_SERVER_THREADS=4
CORS_ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Chainlit Web UI container runtime.
# Compose sets FASTAPI_BASE_URL to http://fastapi:8000 inside the webui service.
WEBUI_DATABASE_URL=postgresql+psycopg://language_agent:change-me@postgres:5432/language_agent
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8001
WEBUI_REQUEST_TIMEOUT_SECONDS=120
WEBUI_STREAMING_ENABLED=true
DEBUG=false
