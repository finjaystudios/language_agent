# Copy to .env for `docker compose ...`, or pass with:
# docker compose --env-file .env.compose.example up --build

LOG_LEVEL=INFO

# Shared service-to-service API key used by both containers.
# Replace this placeholder in your local .env; do not commit real secrets.
AUTH_ENABLED=true
FASTAPI_API_KEY=local-dev-change-me

# FastAPI container runtime.
APP_HOST=0.0.0.0
APP_PORT=8000
LLM_MODEL_PATH=/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLM_CONTEXT_SIZE=4096
LLM_N_GPU_LAYERS=-1
LLM_THREADS=4
LLM_RESERVED_VRAM_GB=1.5
CORS_ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Chainlit Web UI container runtime.
# Compose sets FASTAPI_BASE_URL to http://fastapi:8000 inside the webui service.
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8001
WEBUI_REQUEST_TIMEOUT_SECONDS=120
WEBUI_STREAMING_ENABLED=true
DEBUG=false
