# syntax=docker/dockerfile:1.7

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    FASTAPI_BASE_URL=http://fastapi:8000 \
    WEBUI_HOST=0.0.0.0 \
    WEBUI_PORT=8001 \
    WEBUI_REQUEST_TIMEOUT_SECONDS=120 \
    WEBUI_STREAMING_ENABLED=true \
    DEBUG=false \
    LOG_LEVEL=INFO

WORKDIR /app/webui

COPY webui/requirements.txt .

RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    python -m pip install --upgrade pip \
    && python -m pip install --no-compile -r requirements.txt

COPY webui/*.py webui/chainlit.md ./
COPY webui/.chainlit/config.toml ./.chainlit/config.toml
COPY webui/public ./public

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import os, urllib.request; urllib.request.urlopen(f'http://127.0.0.1:{os.getenv(\"WEBUI_PORT\", \"8001\")}/', timeout=3).read()"

CMD ["sh", "-c", "python -m chainlit run app.py --headless --host \"$WEBUI_HOST\" --port \"$WEBUI_PORT\""]
