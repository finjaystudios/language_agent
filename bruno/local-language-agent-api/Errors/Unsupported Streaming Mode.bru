meta {
  name: Unsupported Streaming Mode
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/chat/stream
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "message": "Define recursion in simple terms",
    "mode": "definition",
    "stream": true
  }
}

tests {
  test("returns HTTP 400", function () {
    expect(res.getStatus()).to.equal(400);
  });

  test("explains unsupported streaming mode", function () {
    const body = res.getBody();
    expect(body.error).to.equal("unsupported_mode");
    expect(body.message).to.include("definition");
  });
}
