meta {
  name: Invalid Mode
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/chat
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
  X-API-Key: {{apiKey}}
}

body:json {
  {
    "message": "Hello",
    "mode": "unsupported"
  }
}

tests {
  test("returns HTTP 400", function () {
    expect(res.getStatus()).to.equal(400);
  });

  test("returns validation error shape", function () {
    const body = res.getBody();
    expect(body.error).to.equal("validation_error");
    expect(body.message).to.equal("Request validation failed.");
  });
}
